# Gork Scape is a fast-moving dev build. Code (html + JS modules) must never be
# served stale — the #1 report was two devices showing different versions. So:
# no-store on the entry point + all source modules; models/images revalidate.
/*
  Cache-Control: no-cache
/index.html
  Cache-Control: no-store
/src/*
  Cache-Control: no-store
